# ── Database ──────────────────────────────────────────────────────────────────
# Supabase connection pooler URL (port 6543, pgbouncer=true) — used at runtime
DATABASE_URL="postgresql://postgres:<password>@<host>:6543/<db>?pgbouncer=true"
# Supabase direct connection (port 5432) — used for migrations only
DIRECT_URL="postgresql://postgres:<password>@<host>:5432/<db>"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ── JWT (RS256) ───────────────────────────────────────────────────────────────
# Generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Paste as single line with \n for newlines
JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ── MFA (TOTP) ────────────────────────────────────────────────────────────────
TOTP_ISSUER="Caminet"

# ── Cryptographic Tag Verification ────────────────────────────────────────────
# Random 32+ char secret used to HMAC-sign QR/RFID tag payloads
HMAC_TAG_SECRET="replace-with-32-char-random-secret"

# ── Email (Nodemailer via Gmail SMTP) ─────────────────────────────────────────
# Use a Gmail App Password (not your account password)
# Generate at: myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="Caminet <your-gmail@gmail.com>"

# ── Cloudinary (issue report photo storage) ───────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Firebase (push notifications via FCM) ─────────────────────────────────────
# Paste the full JSON content of your Firebase service account key file
FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'
